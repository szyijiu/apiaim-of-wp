# ApiAim Proxy API Configuration
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=production

# Database (same as apiaim.com New API database)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=new_api
DB_USER=root
DB_PASSWORD=your_password_here

# API Authentication
# Generate a strong random string: openssl rand -hex 32
API_KEY_PROXY=aigogogo_xxxxxxxxxxxxxxxxxxxxxxxx

# Security
# Request timeout in seconds
REQUEST_TIMEOUT=30
# Max retry attempts for failed sync
MAX_RETRY_ATTEMPTS=5

# Logging (DO NOT log sensitive data)
LOG_LEVEL=info
